{
  "name": "ShaprAI",
  "description": "Agent lifecycle management platform - Sharpens raw models into principled, self-governing Elyan-class agents",
  "version": "0.1.0",
  "protocols": ["mcp", "a2a", "http"],
  "capabilities": [
    "template-engine",
    "lifecycle-management",
    "driftlock",
    "fleet-management",
    "sanctuary",
    "agent-training",
    "agent-deployment"
  ],
  "endpoints": {
    "api": "https://api.shaprai.elyanlabs.com",
    "documentation": "https://github.com/Scottcjn/shaprai",
    "mcp": "https://mcp.shaprai.elyanlabs.com"
  },
  "authentication": {
    "required": true,
    "methods": ["api-key", "oauth2"]
  },
  "mcpTools": [
    "shaprai create",
    "shaprai train",
    "shaprai deploy",
    "shaprai evaluate",
    "shaprai graduate",
    "shaprai sanctuary",
    "shaprai fleet status",
    "shaprai template list"
  ]
}
